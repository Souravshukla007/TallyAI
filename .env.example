# TallyAI UI environment configuration
#
# Toggle the API adapter the UI talks to.
#   true  (default) → in-memory mock adapter (demo / no backend needed)
#   false           → HTTP adapter calling the FastAPI backend
NEXT_PUBLIC_USE_MOCK=true

# Base URL of the FastAPI backend (used only when NEXT_PUBLIC_USE_MOCK=false).
# Must include the /api/v1 version prefix.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# MVP tenant scope. The backend resolves the tenant from the bearer token in
# production; for the MVP it accepts a tenant_id query param + X-Tenant-Id header.
NEXT_PUBLIC_TENANT_ID=demo-tenant

# MVP user scope for per-user history.
NEXT_PUBLIC_USER_ID=default-user

# --- Supabase Auth (frontend) ---
# Used for user authentication (login / sign up). Find these in your Supabase
# project: Settings → API. Without them the auth page renders but login is disabled.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
