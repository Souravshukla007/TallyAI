# TallyAI — environment variables
# Copy this file to .env and fill in real values before starting the server.
# Never commit .env to version control.

# --- Database ---
# SQLAlchemy async connection URL, e.g.:
#   postgresql+asyncpg://user:password@localhost:5432/mydb
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tallyai

# --- Security ---
# A long, random secret used for token signing.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-with-a-long-random-secret

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Defaults to http://localhost:3000 when not set.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Safety / Query limits ---
# Maximum number of rows any single query may return.
ROW_CAP=1000

# Maximum wall-clock time a query may run before being terminated (milliseconds).
QUERY_TIMEOUT_MS=30000

# --- LLM provider ---
# Which LLM provider to use. Supported: openai, anthropic, gemini
LLM_PROVIDER=gemini

# The model name to use for SQL generation and reasoning.
#   openai:    gpt-4o
#   anthropic: claude-3-5-sonnet-latest
#   gemini:    gemini-2.0-flash  (free tier friendly)
LLM_MODEL=gemini-2.0-flash

# API key for the selected provider. Set ONLY the one you use:
#   openai    -> OPENAI_API_KEY
#   anthropic -> ANTHROPIC_API_KEY
#   gemini    -> GOOGLE_API_KEY
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
